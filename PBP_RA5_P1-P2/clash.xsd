<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">
    
    <xs:element name="clash">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="versio" type="xs:string"/>
                <xs:element name="jugador" maxOccurs="unbounded">
                    <xs:complexType>
                        <xs:sequence>
                            <xs:element name="nom" type="xs:string"/>
                            <xs:element name="copes" type="xs:integer"/>
                            <xs:element name="nivell">
                                <xs:simpleType>
                                    <xs:restriction base="xs:integer">
                                        <xs:minInclusive value="1"/>
                                        <xs:maxInclusive value="14"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>

                            <xs:element name="carta" maxOccurs="unbounded">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element name="nomCarta" type="xs:string"/>
                                        <xs:element name="nivellCarta">
                                            <xs:simpleType>
                                                <xs:restriction base="xs:integer">
                                                    <xs:minInclusive value="1"/>
                                                    <xs:maxInclusive value="14"/>
                                                </xs:restriction>
                                            </xs:simpleType>
                                        </xs:element>
                                        <xs:element name="raresa">
                                            <xs:simpleType>
                                                <xs:restriction base="xs:string">
                                                    <xs:enumeration value="comuna"/>
                                                    <xs:enumeration value="rara"/>
                                                    <xs:enumeration value="epica"/>
                                                    <xs:enumeration value="llegendaria"/>
                                                    <xs:enumeration value="heroi"/>
                                                </xs:restriction>
                                            </xs:simpleType>
                                        </xs:element>
                                    </xs:sequence>

                                    <xs:attribute name="idCarta" type="xs:integer"/>
                                </xs:complexType>
                            </xs:element>
                        </xs:sequence>

                        <xs:attribute name="id" type="xs:integer"/>
                    </xs:complexType>
                </xs:element>
            </xs:sequence>
        </xs:complexType> 
    </xs:element>
</xs:schema>